default_platform(:mac)

platform :mac do
  desc "Bump version, build, and upload to App Store Connect"
  lane :release do |options|
    # Default to patch if no type specified
    bump_type = options[:type] || "patch"

    # Get current version from project
    current_version = get_version_number(
      xcodeproj: "json-assistant.xcodeproj",
      target: "json-assistant"
    )

    # Parse and bump version manually
    version_parts = current_version.split(".").map(&:to_i)
    version_parts = [1, 0, 0] if version_parts.length < 3

    case bump_type
    when "major"
      version_parts[0] += 1
      version_parts[1] = 0
      version_parts[2] = 0
    when "minor"
      version_parts[1] += 1
      version_parts[2] = 0
    when "patch"
      version_parts[2] += 1
    when "build"
      # Don't change version, only build number
    end

    new_version = version_parts.join(".")

    # Update version in project using sed (works reliably)
    if bump_type != "build"
      sh("sed -i '' 's/MARKETING_VERSION = #{current_version};/MARKETING_VERSION = #{new_version};/g' ../json-assistant.xcodeproj/project.pbxproj")
    end

    # Increment build number
    increment_build_number(xcodeproj: "json-assistant.xcodeproj")
    new_build = get_build_number(xcodeproj: "json-assistant.xcodeproj")

    UI.message("📦 Building v#{new_version} (#{new_build})...")

    # Build the app
    build_mac_app(
      scheme: "json-assistant",
      clean: true,
      output_directory: "./build",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        provisioningProfiles: {}
      }
    )

    # Upload to App Store Connect
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      precheck_include_in_app_purchases: false,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    # Commit version bump
    git_commit(
      path: ["json-assistant.xcodeproj/project.pbxproj"],
      message: "chore: bump version to #{new_version} (#{new_build})\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>"
    )

    # Tag the release
    add_git_tag(tag: "v#{new_version}")

    UI.success("🚀 Successfully uploaded v#{new_version} (#{new_build}) to App Store Connect!")
  end

  desc "Build only (no upload)"
  lane :build do
    build_mac_app(
      scheme: "json-assistant",
      clean: true,
      output_directory: "./build",
      export_method: "app-store"
    )
    UI.success("✅ Build complete! Archive saved to ./build")
  end

  desc "Upload existing build to App Store Connect"
  lane :upload do
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      precheck_include_in_app_purchases: false,
      pkg: "./build/json-assistant.pkg",
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
  end
end
